{
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "composite":       true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl":         ".",
    "paths":           { "@/*": ["./src/*"] },
    "target":          "ES2020",
    "module":          "ESNext",
    "moduleResolution":"bundler",
    "lib":             ["ES2020", "DOM", "DOM.Iterable"],
    "strict":          false,
    "jsx":             "preserve",
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit":          true
  }
}
